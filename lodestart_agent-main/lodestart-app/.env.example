# ============================================================
#  Copy this file to  .env.local  and fill in the values.
#  NEVER commit .env.local to GitHub. (.gitignore already blocks it.)
# ============================================================

# --- 1. Anthropic (Claude API) ---------------------------------
# Get from https://console.anthropic.com  ->  API Keys  ->  Create Key
# You must add >= $5 credit under Billing first.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- 2. Supabase ------------------------------------------------
# Get from https://supabase.com  ->  your project  ->  Settings  ->  API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGcixxxxxxxxxxxxxxxxxxxx

# --- 3. Google OAuth (Gmail draft) ------------------------------
# Get from https://console.cloud.google.com
#   APIs & Services -> Credentials -> Create OAuth client ID (Web application)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# The redirect URL Google sends the user back to after login.
# Local:      http://localhost:3000/api/auth/callback
# Production: https://YOUR-APP.vercel.app/api/auth/callback
# Set this to match wherever you're running. Must EXACTLY match what you
# enter in the Google console "Authorized redirect URIs".
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ---------------------------------------------------------------
# CSV export gating (PDPA)
# The contacts DB holds names, titles and work emails of real people.
# Only accounts on these domains may export it. Comma-separated,
# no @. Defaults to lodestart.ai if unset.
STAFF_EMAIL_DOMAINS=lodestart.ai
# Optional individual exceptions (e.g. a consultant on gmail.com).
STAFF_EMAIL_ALLOWLIST=
